{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "//": "Project-shared Claude Code settings. Conservative allowlist of read-only and local-only operations that come up constantly when working in this repo. Anything that writes to a remote, modifies global state, or could leak plaintext is deliberately omitted — those should still prompt. Personal overrides go in .claude/settings.local.json (gitignored).",
  "permissions": {
    "allow": [
      "Bash(make build)",
      "Bash(make test)",
      "Bash(make lint)",
      "Bash(make fmt)",
      "Bash(go build ./...)",
      "Bash(go test ./...)",
      "Bash(go test -race ./...)",
      "Bash(go test ./internal/...)",
      "Bash(go vet ./...)",
      "Bash(go mod download)",
      "Bash(go mod tidy)",
      "Bash(go fmt ./...)",
      "Bash(gofmt -l .)",
      "Bash(gofmt -d .)",
      "Bash(golangci-lint run)",
      "Bash(~/go/bin/golangci-lint run)",
      "Bash(git status)",
      "Bash(git diff)",
      "Bash(git diff --stat)",
      "Bash(git diff --cached)",
      "Bash(git log)",
      "Bash(git log --oneline)",
      "Bash(git log --oneline -*)",
      "Bash(git show)",
      "Bash(git branch)",
      "Bash(git branch -a)",
      "Bash(git remote -v)",
      "Bash(go version)",
      "Bash(sops --version)",
      "Bash(age --version)"
    ]
  }
}
